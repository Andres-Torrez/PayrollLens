# GitHub Models (Personal Access Token con permiso models)
# Consíguelo en: https://github.com/settings/tokens
GITHUB_TOKEN=tu_github_token_aqui

# Base de datos (SQLite) — por defecto: backend/nominaflow.db (ruta absoluta)
# DATABASE_URL=sqlite:///C:/ruta/absoluta/a/nominaflow.db

# Entorno
ENVIRONMENT=development
